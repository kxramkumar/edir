# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv
.llm

# Jupyter
.ipynb_checkpoints/

# Artifacts — ignore data contents but keep directory structure via .gitkeep
art/data/raw/*
!art/data/raw/.gitkeep
art/data/clean/*
!art/data/clean/.gitkeep

