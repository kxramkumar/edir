# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv
.llm

# Jupyter
.ipynb_checkpoints/

# Resource — ignore data contents but keep directory structure via .gitkeep
res/_common/data/raw/*
!res/_common/.gitkeep
!res/_common/data/raw/.gitkeep

res/*/data/prep/*
res/*/data/aug/*
!res/*/data/prep/.gitkeep
!res/*/data/aug/.gitkeep
